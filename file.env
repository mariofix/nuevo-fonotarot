# Example environment file for nuevo-fonotarot.
# Copy this file to .env and fill in the values.

# Flask secret key (required) — change this to a long random string.
SECRET_KEY=change-me-to-a-random-secret-key

# Database URL (SQLAlchemy connection string).
# Default: SQLite database in the instance folder.
DATABASE_URL=sqlite:///fonotarot.db

# Flask environment: development | production | testing
FLASK_ENV=development

# Enable Flask debug mode (true/false)
FLASK_DEBUG=true

# Rate limiting storage backend URI (optional).
# Defaults to in-memory storage when not set.
# Example with Redis: redis://localhost:6379/0
RATELIMIT_STORAGE_URI=memory://

# Flask-Security password salt (required) — change this to a long random string.
SECURITY_PASSWORD_SALT=change-me-to-a-random-password-salt

# Flask-Admin / Flask-Babel locale (en_US | es_CL | pt_BR)
ADMIN_LOCALE=en_US
